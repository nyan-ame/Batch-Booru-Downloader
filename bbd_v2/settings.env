# Batch Booru Downloader portable settings
# Edit this file before first real use.

LANG=en

APP_LOG_LEVEL=INFO
APP_LOG_TO_CONSOLE=true
DOWNLOAD_DIR=downloads
LINKS_DIR=links
LOGS_DIR=logs
TOKENS_DIR=tokens
REQUEST_DELAY=1.1
MAX_RETRIES=3
CHUNK_SIZE=262144
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36

DANBOORU_USERNAME=
DANBOORU_API_KEY=
DANBOORU_USE_CURL_CFFI=true
DANBOORU_IMPERSONATE=chrome
DANBOORU_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36
DANBOORU_COOKIE_TTL_MINUTES=30

GELBOORU_USERNAME=
GELBOORU_API_KEY=
GELBOORU_USER_ID=

# Konachan / yande.re (moebooru): auth is optional but recommended to avoid throttling.
# Set USERNAME plus either PASSWORD (auto-hashed with the site salt) or a
# precomputed PASSWORD_HASH. The legacy API_KEY field still works as a fallback.
KONACHAN_USERNAME=
KONACHAN_PASSWORD=
KONACHAN_PASSWORD_HASH=
KONACHAN_API_KEY=

YANDERE_USERNAME=
YANDERE_PASSWORD=
YANDERE_PASSWORD_HASH=

SANKAKU_LOGIN=
SANKAKU_PASSWORD=

PIXIV_UGOIRA_CONVERSION_MODE=gif_only

CHECK_LIBRARY_UPDATES=true

# Twitter/X: yt-dlp first, fxtwitter fallback for photos.
TWITTER_USE_FXTWITTER=true
